# General
USERNAME=omni
USER_UID=1000
USER_GID=1000

HOME_PATH=/home/host
PROJECTS_PATH=/home/host/Projects
DATA_PATH=/home/host/.omni/data
TIMEZONE=UTC

# Caddy
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# MySQL
MYSQL_VERSION=latest
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=default
MYSQL_USER=omni
MYSQL_PASSWORD=password
MYSQL_PORT=3306

# MongoDB
MONGO_VERSION=latest
MONGO_USER=omni
MONGO_PASSWORD=password
MONGO_PORT=27017

# Redis
REDIS_VERSION=latest
REDIS_PASSWORD=password
REDIS_PORT=6379

# Mailpit
MAILPIT_HTTP_PORT=8025
MAILPIT_SMTP_PORT=1025

# Arcane
ARCANE_ENCRYPTION_KEY=arcane-dev-key-32-characters!!!
ARCANE_JWT_SECRET=default-jwt-secret-change-me
